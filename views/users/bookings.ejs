<% layout("/layouts/boilerplate") %>

<div class="container my-4">
  <div class="d-flex align-items-center justify-content-between mb-4">
    <div>
      <h2 class="fw-bold mb-1"><i class="fa-solid fa-suitcase text-danger me-2"></i>Your Booked Stays</h2>
      <p class="text-muted mb-0">Manage your active reservations and trip details</p>
    </div>
    <a href="/listings" class="btn btn-outline-dark rounded-pill px-4 fw-semibold">
      <i class="fa-solid fa-compass me-2"></i>Explore Stays
    </a>
  </div>

  <% if (userBookings.length === 0) { %>
    <div class="text-center py-5 my-4 bg-white rounded-4 border shadow-sm">
      <div class="display-3 text-muted mb-3"><i class="fa-solid fa-plane-departure"></i></div>
      <h4 class="fw-bold">No trips booked yet</h4>
      <p class="text-muted">Time to dust off your bags and start planning your next great adventure!</p>
      <a href="/listings" class="btn btn-danger rounded-pill px-4 mt-2">Find a Place to Stay</a>
    </div>
  <% } else { %>
    <div class="row row-cols-1 g-4 mb-5">
      <% for(let booking of userBookings) { %>
        <% if (booking.listing) { %>
          <div class="col">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden bg-white">
              <div class="row g-0 align-items-center">
                <div class="col-md-4 col-lg-3">
                  <img 
                    src="<%= booking.listing.image ? booking.listing.image.url : 'https://images.unsplash.com/photo-1507525428034-b723cf961d3e' %>" 
                    class="img-fluid w-100" 
                    style="height: 220px; object-fit: cover;" 
                    alt="<%= booking.listing.title %>"
                  >
                </div>
                <div class="col-md-8 col-lg-9">
                  <div class="card-body p-4">
                    <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center mb-3">
                      <div>
                        <span class="badge <%= booking.status === 'Confirmed' ? 'bg-success' : 'bg-secondary' %> rounded-pill px-3 py-2 me-2">
                          <i class="fa-solid fa-circle-check me-1"></i><%= booking.status %>
                        </span>
                        <span class="text-muted small"><i class="fa-solid fa-location-dot me-1 text-danger"></i><%= booking.listing.location %>, <%= booking.listing.country %></span>
                        <h4 class="fw-bold mt-2 mb-0"><%= booking.listing.title %></h4>
                      </div>
                      <div class="text-md-end mt-3 mt-md-0">
                        <span class="fs-4 fw-bold text-dark">&#8377;<%= booking.totalPrice ? booking.totalPrice.toLocaleString("en-IN") : '0' %></span>
                        <div class="text-muted small">Total paid</div>
                      </div>
                    </div>

                    <div class="row g-3 bg-light rounded-3 p-3 my-2 border">
                      <div class="col-6 col-md-3">
                        <span class="text-uppercase text-muted fw-bold fs-7">Check-in</span>
                        <div class="fw-bold text-dark"><%= new Date(booking.checkIn).toLocaleDateString("en-IN", { day: 'numeric', month: 'short', year: 'numeric' }) %></div>
                      </div>
                      <div class="col-6 col-md-3">
                        <span class="text-uppercase text-muted fw-bold fs-7">Checkout</span>
                        <div class="fw-bold text-dark"><%= new Date(booking.checkOut).toLocaleDateString("en-IN", { day: 'numeric', month: 'short', year: 'numeric' }) %></div>
                      </div>
                      <div class="col-6 col-md-3">
                        <span class="text-uppercase text-muted fw-bold fs-7">Guests</span>
                        <div class="fw-bold text-dark"><%= booking.guests %> Guest<%= booking.guests > 1 ? 's' : '' %></div>
                      </div>
                      <div class="col-6 col-md-3">
                        <span class="text-uppercase text-muted fw-bold fs-7">Host</span>
                        <div class="fw-bold text-dark">@<%= booking.listing.owner ? booking.listing.owner.username : 'Host' %></div>
                      </div>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mt-3">
                      <a href="/listings/<%= booking.listing._id %>" class="btn btn-sm btn-outline-dark rounded-pill px-3">
                        View Listing Details
                      </a>
                      
                      <% if (booking.status === 'Confirmed') { %>
                        <form method="post" action="/bookings/<%= booking._id %>?_method=DELETE" onsubmit="return confirm('Are you sure you want to cancel this booking reservation?');">
                          <button class="btn btn-sm btn-outline-danger border-0">
                            <i class="fa-solid fa-xmark me-1"></i>Cancel Reservation
                          </button>
                        </form>
                      <% } %>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        <% } %>
      <% } %>
    </div>
  <% } %>
</div>
