<% layout("/layouts/boilerplate") %>

<div class="container my-4">
  <div class="d-flex align-items-center justify-content-between mb-4">
    <div>
      <h2 class="fw-bold mb-1"><i class="fa-solid fa-chart-line text-danger me-2"></i>Host Analytics & Control Center</h2>
      <p class="text-muted mb-0">Track earnings, manage your listings, and oversee guest reservation requests</p>
    </div>
    <a href="/listings/new" class="btn btn-danger rounded-pill px-4 fw-semibold">
      <i class="fa-solid fa-plus me-2"></i>Add New Listing
    </a>
  </div>

  <!-- Key Metrics Row -->
  <div class="row row-cols-1 row-cols-md-4 g-3 mb-5">
    <div class="col">
      <div class="card border-0 shadow-sm p-3 rounded-4 bg-white h-100">
        <div class="d-flex align-items-center gap-3">
          <div class="rounded-circle bg-danger-subtle p-3 text-danger fs-4">
            <i class="fa-solid fa-sack-dollar"></i>
          </div>
          <div>
            <div class="text-muted small fw-bold text-uppercase">Total Revenue</div>
            <h3 class="fw-bold mb-0 text-dark">&#8377;<%= totalRevenue ? totalRevenue.toLocaleString("en-IN") : '0' %></h3>
          </div>
        </div>
      </div>
    </div>

    <div class="col">
      <div class="card border-0 shadow-sm p-3 rounded-4 bg-white h-100">
        <div class="d-flex align-items-center gap-3">
          <div class="rounded-circle bg-primary-subtle p-3 text-primary fs-4">
            <i class="fa-solid fa-house-user"></i>
          </div>
          <div>
            <div class="text-muted small fw-bold text-uppercase">Active Properties</div>
            <h3 class="fw-bold mb-0 text-dark"><%= totalStays %></h3>
          </div>
        </div>
      </div>
    </div>

    <div class="col">
      <div class="card border-0 shadow-sm p-3 rounded-4 bg-white h-100">
        <div class="d-flex align-items-center gap-3">
          <div class="rounded-circle bg-success-subtle p-3 text-success fs-4">
            <i class="fa-solid fa-calendar-check"></i>
          </div>
          <div>
            <div class="text-muted small fw-bold text-uppercase">Total Bookings</div>
            <h3 class="fw-bold mb-0 text-dark"><%= totalBookings %></h3>
          </div>
        </div>
      </div>
    </div>

    <div class="col">
      <div class="card border-0 shadow-sm p-3 rounded-4 bg-white h-100">
        <div class="d-flex align-items-center gap-3">
          <div class="rounded-circle bg-warning-subtle p-3 text-warning fs-4">
            <i class="fa-solid fa-star"></i>
          </div>
          <div>
            <div class="text-muted small fw-bold text-uppercase">Host Rating</div>
            <h3 class="fw-bold mb-0 text-dark">4.92 / 5</h3>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Reservation Requests Table -->
  <div class="card border-0 shadow-sm rounded-4 p-4 mb-5 bg-white">
    <h4 class="fw-bold mb-3"><i class="fa-solid fa-list-check me-2 text-danger"></i>Guest Reservation Requests</h4>

    <% if (hostBookings.length === 0) { %>
      <p class="text-muted mb-0 py-3">No reservation requests received yet for your properties.</p>
    <% } else { %>
      <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
          <thead class="table-light">
            <tr>
              <th>Guest</th>
              <th>Property</th>
              <th>Check-in</th>
              <th>Checkout</th>
              <th>Guests</th>
              <th>Total Earnings</th>
              <th>Status</th>
            </tr>
          </thead>
          <tbody>
            <% for(let booking of hostBookings) { %>
              <tr>
                <td>
                  <div class="fw-bold text-dark">@<%= booking.user ? booking.user.username : 'Guest' %></div>
                  <span class="text-muted small"><%= booking.user ? booking.user.email : '' %></span>
                </td>
                <td class="fw-semibold">
                  <a href="/listings/<%= booking.listing ? booking.listing._id : '' %>" class="text-dark text-decoration-none">
                    <%= booking.listing ? booking.listing.title : 'Listing' %>
                  </a>
                </td>
                <td><%= new Date(booking.checkIn).toLocaleDateString("en-IN", { day: 'numeric', month: 'short', year: 'numeric' }) %></td>
                <td><%= new Date(booking.checkOut).toLocaleDateString("en-IN", { day: 'numeric', month: 'short', year: 'numeric' }) %></td>
                <td><%= booking.guests %></td>
                <td class="fw-bold text-dark">&#8377;<%= booking.totalPrice ? booking.totalPrice.toLocaleString("en-IN") : '0' %></td>
                <td>
                  <span class="badge <%= booking.status === 'Confirmed' ? 'bg-success' : 'bg-secondary' %> rounded-pill px-3 py-2">
                    <%= booking.status %>
                  </span>
                </td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>

  <!-- Host Properties List -->
  <div class="card border-0 shadow-sm rounded-4 p-4 bg-white mb-5">
    <h4 class="fw-bold mb-3"><i class="fa-solid fa-house-laptop me-2 text-danger"></i>Your Hosted Properties (<%= myListings.length %>)</h4>

    <% if (myListings.length === 0) { %>
      <div class="text-center py-4">
        <p class="text-muted">You haven't added any listings yet.</p>
        <a href="/listings/new" class="btn btn-danger rounded-pill px-4">Create Your First Listing</a>
      </div>
    <% } else { %>
      <div class="row row-cols-1 row-cols-md-3 g-3">
        <% for(let listing of myListings) { %>
          <div class="col">
            <div class="card border rounded-3 overflow-hidden h-100">
              <img src="<%= listing.image ? listing.image.url : 'https://images.unsplash.com/photo-1507525428034-b723cf961d3e' %>" class="card-img-top" style="height: 140px; object-fit: cover;" alt="<%= listing.title %>">
              <div class="card-body p-3">
                <h6 class="fw-bold mb-1 text-truncate"><%= listing.title %></h6>
                <div class="text-muted small mb-2"><i class="fa-solid fa-location-dot me-1 text-danger"></i><%= listing.location %></div>
                <div class="d-flex justify-content-between align-items-center mt-2">
                  <span class="fw-bold text-dark">&#8377;<%= listing.price ? listing.price.toLocaleString("en-IN") : 0 %> / night</span>
                  <a href="/listings/<%= listing._id %>/edit" class="btn btn-sm btn-outline-dark rounded-pill px-3">Edit</a>
                </div>
              </div>
            </div>
          </div>
        <% } %>
      </div>
    <% } %>
  </div>
</div>
