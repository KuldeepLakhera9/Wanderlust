<!-- Floating AI Assistant Button -->
<div class="ai-widget-button-wrapper">
  <button id="aiWidgetToggle" class="btn btn-danger rounded-pill px-4 py-2 shadow-lg fw-bold d-flex align-items-center gap-2" title="Wanderlust AI Travel Assistant">
    <i class="fa-solid fa-wand-magic-sparkles fs-5"></i>
    <span>AI Concierge</span>
  </button>
</div>

<!-- Glassmorphic AI Chat Drawer -->
<div id="aiChatDrawer" class="ai-chat-drawer d-none shadow-lg">
  <!-- Chat Header -->
  <div class="ai-chat-header d-flex align-items-center justify-content-between p-3 border-bottom text-white">
    <div class="d-flex align-items-center gap-2">
      <div class="ai-avatar-icon">
        <i class="fa-solid fa-wand-magic-sparkles"></i>
      </div>
      <div>
        <h6 class="fw-bold mb-0">Wanderlust AI Assistant</h6>
        <span class="text-white-50 small"><i class="fa-solid fa-circle text-success me-1 fs-8"></i>Online &bull; Ready to help</span>
      </div>
    </div>
    <button id="aiChatClose" class="btn btn-sm btn-link text-white p-0 fs-5 border-0">
      <i class="fa-solid fa-xmark"></i>
    </button>
  </div>

  <!-- Chat Messages Stream -->
  <div id="aiChatStream" class="ai-chat-stream p-3">
    <!-- Welcome Bot Message -->
    <div class="ai-msg bot-msg mb-3">
      <div class="msg-content p-3 rounded-4 shadow-sm bg-white border">
        Hello 👋! I'm your <strong>Wanderlust AI Travel Assistant</strong>. Where are you planning to go next?
        <div class="mt-2 text-muted small">Try asking me to find stays, plan itineraries, or filter by budget!</div>
      </div>
    </div>

    <!-- Quick Prompt Chips -->
    <div id="aiQuickChips" class="d-flex flex-wrap gap-2 mb-3">
      <button class="chip-btn" data-prompt="Show me beach stays in Goa under ₹5,000">🏖️ Goa under ₹5k</button>
      <button class="chip-btn" data-prompt="Find me peaceful mountain cabins">⛰️ Mountain Cabins</button>
      <button class="chip-btn" data-prompt="Suggest a 3-day travel itinerary">💡 3-Day Itinerary</button>
      <button class="chip-btn" data-prompt="What stays have private pools?">🏊 Places with Pools</button>
    </div>
  </div>

  <!-- Chat Input Form -->
  <div class="ai-chat-footer p-3 border-top bg-white">
    <form id="aiChatForm" class="d-flex gap-2">
      <input 
        type="text" 
        id="aiChatInput" 
        class="form-control rounded-pill border shadow-none px-3" 
        placeholder="Ask anything (e.g. 'Stays in Goa under 3k')..." 
        required 
        autocomplete="off"
      >
      <button type="submit" class="btn btn-danger rounded-circle p-2 px-3 shadow-sm d-flex align-items-center justify-content-center">
        <i class="fa-solid fa-paper-plane"></i>
      </button>
    </form>
  </div>
</div>
