<% layout("/layouts/boilerplate") %>

<div class="container my-4">
  <!-- Title & Top Info Header -->
  <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center mb-3">
    <div>
      <div class="d-flex align-items-center gap-2 mb-1">
        <span class="badge bg-dark rounded-pill px-3 py-2"><%= listing.category || 'Trending' %></span>
        <span class="text-muted"><i class="fa-solid fa-location-dot me-1 text-danger"></i><%= listing.location %>, <%= listing.country %></span>
      </div>
      <h2 class="show-title-header"><%= listing.title %></h2>
    </div>

    <% if (currUser && listing.owner && currUser._id.equals(listing.owner._id)) { %>
      <div class="d-flex gap-2 mt-3 mt-md-0">
        <a href="/listings/<%= listing._id %>/edit" class="btn btn-outline-dark rounded-pill px-4 fw-semibold">
          <i class="fa-solid fa-pen-to-square me-1"></i>Edit Listing
        </a>
        <form method="post" action="/listings/<%= listing._id %>?_method=DELETE" class="d-inline">
          <button class="btn btn-danger rounded-pill px-4 fw-semibold">
            <i class="fa-solid fa-trash me-1"></i>Delete
          </button>
        </form>
      </div>
    <% } %>
  </div>

  <!-- Main Hero Image Showcase -->
  <div class="show-img-container mb-4">
    <img 
      src="<%= listing.image ? listing.image.url : 'https://images.unsplash.com/photo-1507525428034-b723cf961d3e' %>" 
      alt="<%= listing.title %>"
    >
  </div>

  <!-- Content Split Layout: Details Left, Booking Widget Right -->
  <div class="row g-4">
    <!-- Left Column: Details & Amenities & Map & Reviews -->
    <div class="col-lg-7">
      <!-- Host Card -->
      <div class="d-flex align-items-center gap-3 p-3 bg-white rounded-4 border mb-4 shadow-sm">
        <div class="host-avatar-badge">
          <%= listing.owner && listing.owner.username ? listing.owner.username.charAt(0).toUpperCase() : 'H' %>
        </div>
        <div>
          <h5 class="fw-bold mb-0">Entire stay hosted by <%= listing.owner ? listing.owner.username : 'Wanderlust Partner' %></h5>
          <p class="text-muted small mb-0"><i class="fa-solid fa-shield-halved me-1 text-success"></i>Verified Superhost &bull; Fast response time</p>
        </div>
      </div>

      <!-- Description -->
      <div class="mb-4">
        <h4 class="fw-bold mb-3">About this place</h4>
        <p class="fs-6 text-secondary lh-lg"><%= listing.description %></p>
      </div>

      <hr class="my-4">

      <!-- Offer / Amenities Grid -->
      <div class="mb-4">
        <h4 class="fw-bold mb-3">What this place offers</h4>
        <div class="row row-cols-2 g-3">
          <div class="col"><div class="amenity-chip"><i class="fa-solid fa-wifi"></i>High-speed Wi-Fi</div></div>
          <div class="col"><div class="amenity-chip"><i class="fa-solid fa-square-parking"></i>Free on-premise parking</div></div>
          <div class="col"><div class="amenity-chip"><i class="fa-solid fa-snowflake"></i>Air conditioning</div></div>
          <div class="col"><div class="amenity-chip"><i class="fa-solid fa-utensils"></i>Chef's Kitchen</div></div>
          <div class="col"><div class="amenity-chip"><i class="fa-solid fa-tv"></i>4K Smart TV</div></div>
          <div class="col"><div class="amenity-chip"><i class="fa-solid fa-water-ladder"></i>Private Pool Access</div></div>
        </div>
      </div>

      <hr class="my-4">

      <!-- Leaflet Interactive Map -->
      <div class="mb-4">
        <h4 class="fw-bold mb-2">Where you'll be</h4>
        <p class="text-muted mb-3"><i class="fa-solid fa-map-pin me-1 text-danger"></i><%= listing.location %>, <%= listing.country %></p>
        
        <div 
          id="map" 
          data-lat="<%= listing.geometry && listing.geometry.coordinates ? listing.geometry.coordinates[1] : 28.6139 %>" 
          data-lng="<%= listing.geometry && listing.geometry.coordinates ? listing.geometry.coordinates[0] : 77.2090 %>" 
          data-title="<%= listing.title %>" 
          data-location="<%= listing.location %>, <%= listing.country %>"
        ></div>
      </div>
    </div>

    <!-- Right Column: Interactive Booking Widget -->
    <div class="col-lg-5">
      <div class="booking-card">
        <div class="d-flex justify-content-between align-items-baseline mb-3">
          <div>
            <span class="fs-3 fw-bold text-dark" id="nightlyPrice" data-price="<%= listing.price %>">&#8377;<%= listing.price ? listing.price.toLocaleString("en-IN") : '0' %></span>
            <span class="text-muted">/ night</span>
          </div>
          <div class="small fw-semibold text-muted">
            <i class="fa-solid fa-star text-warning me-1"></i>4.95 &bull; <span class="text-decoration-underline"><%= listing.reviews ? listing.reviews.length : 0 %> reviews</span>
          </div>
        </div>

        <div class="border rounded-3 p-2 mb-3 bg-light">
          <div class="row g-2 mb-2">
            <div class="col-6">
              <label class="form-label small fw-bold text-uppercase mb-1">Check-in</label>
              <input type="date" id="checkinDate" class="form-control form-control-sm border-0 bg-white shadow-none">
            </div>
            <div class="col-6">
              <label class="form-label small fw-bold text-uppercase mb-1">Checkout</label>
              <input type="date" id="checkoutDate" class="form-control form-control-sm border-0 bg-white shadow-none">
            </div>
          </div>
          <div class="border-top pt-2">
            <label class="form-label small fw-bold text-uppercase mb-1">Guests</label>
            <select id="guestCount" class="form-select form-select-sm border-0 bg-white shadow-none">
              <option value="1">1 guest</option>
              <option value="2" selected>2 guests</option>
              <option value="3">3 guests</option>
              <option value="4">4 guests</option>
              <option value="5">5+ guests</option>
            </select>
          </div>
        </div>

        <!-- Dynamic Calculation Breakdown -->
        <div id="bookingSummary" class="mb-4">
          <div class="d-flex justify-content-between text-muted mb-2">
            <span>&#8377;<%= listing.price ? listing.price.toLocaleString("en-IN") : '0' %> &times; <span id="calcNightCount">3 nights</span></span>
            <span id="calcBaseSubtotal" class="fw-semibold text-dark">&#8377;0</span>
          </div>
          <div class="d-flex justify-content-between text-muted mb-2">
            <span>18% GST Tax</span>
            <span id="calcGstTax" class="fw-semibold text-dark">&#8377;0</span>
          </div>
          <div class="d-flex justify-content-between text-muted mb-2">
            <span>Cleaning & Service fee</span>
            <span id="calcCleaningFee" class="fw-semibold text-dark">&#8377;0</span>
          </div>
          <hr>
          <div class="d-flex justify-content-between fs-5 fw-bold text-dark">
            <span>Total before taxes</span>
            <span id="calcGrandTotal" class="text-danger">&#8377;0</span>
          </div>
        </div>

        <div id="bookingError" class="alert alert-danger py-2 small d-none mb-3">
          Checkout date must be after Check-in date.
        </div>

        <button class="btn btn-reserve" data-bs-toggle="modal" data-bs-target="#reservationModal">
          Reserve Stay
        </button>

        <p class="text-center text-muted small mt-2 mb-0">You won't be charged yet</p>
      </div>
    </div>
  </div>

  <hr class="my-5">

  <!-- Reviews Section -->
  <div class="mb-5">
    <h3 class="fw-bold mb-4">
      <i class="fa-solid fa-star text-warning me-2"></i>Reviews (<%= listing.reviews ? listing.reviews.length : 0 %>)
    </h3>

    <% if(currUser) { %>
      <div class="card border-0 shadow-sm p-4 rounded-4 mb-4 bg-white">
        <h5 class="fw-bold mb-3">Leave a Review</h5>
        <form action="/listings/<%= listing._id %>/reviews" method="POST" novalidate class="needs-validation">
          <div class="mb-3">
            <label class="form-label fw-semibold">Rating</label>
            <fieldset class="starability-basic">
              <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked aria-label="No rating." />
              <input type="radio" id="first-rate1" name="review[rating]" value="1" />
              <label for="first-rate1" title="Terrible">1 star</label>
              <input type="radio" id="first-rate2" name="review[rating]" value="2" />
              <label for="first-rate2" title="Not good">2 stars</label>
              <input type="radio" id="first-rate3" name="review[rating]" value="3" />
              <label for="first-rate3" title="Average">3 stars</label>
              <input type="radio" id="first-rate4" name="review[rating]" value="4" />
              <label for="first-rate4" title="Very good">4 stars</label>
              <input type="radio" id="first-rate5" name="review[rating]" value="5" />
              <label for="first-rate5" title="Amazing">5 stars</label>
            </fieldset>
          </div>

          <div class="mb-3">
            <label for="comment" class="form-label fw-semibold">Comments</label>
            <textarea name="review[comment]" id="comment" cols="30" rows="3" class="form-control" placeholder="Share details of your stay..." required></textarea>
            <div class="invalid-feedback">Please write a comment before submitting.</div>
          </div>
          <button class="btn btn-dark rounded-pill px-4 fw-semibold">Submit Review</button>
        </form>
      </div>
    <% } %>

    <!-- Review Cards Grid -->
    <div class="row row-cols-md-2 g-3">
      <% for (review of listing.reviews) { %>
        <div class="col">
          <div class="review-card h-100">
            <div class="d-flex justify-content-between align-items-start mb-2">
              <div class="d-flex align-items-center gap-2">
                <div class="reviewer-avatar">
                  <%= review.author && review.author.username ? review.author.username.charAt(0).toUpperCase() : 'U' %>
                </div>
                <div>
                  <h6 class="fw-bold mb-0">@<%= review.author ? review.author.username : 'User' %></h6>
                  <p class="starability-result card-text m-0" data-rating="<%= review.rating %>"></p>
                </div>
              </div>

              <% if(currUser && review.author && currUser._id.equals(review.author._id)) { %>
                <form method="post" action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE">
                  <button class="btn btn-sm btn-outline-danger border-0 rounded-circle" title="Delete Review">
                    <i class="fa-solid fa-trash-can"></i>
                  </button>
                </form>
              <% } %>
            </div>
            <p class="text-secondary small mt-2 mb-0"><%= review.comment %></p>
          </div>
        </div>
      <% } %>
    </div>
  </div>
</div>

<!-- Reservation Confirmation Modal -->
<div class="modal fade" id="reservationModal" tabindex="-1" aria-labelledby="reservationModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content rounded-4 border-0 shadow">
      <div class="modal-header border-0 pb-0">
        <h5 class="modal-title fw-bold" id="reservationModalLabel"><i class="fa-solid fa-circle-check text-success me-2"></i>Reservation Request</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body py-4">
        <p class="mb-2">Your stay request for <strong><%= listing.title %></strong> has been logged!</p>
        <p class="text-muted small">Our host @<%= listing.owner ? listing.owner.username : 'Host' %> will review your request and confirm availability shortly.</p>
      </div>
      <div class="modal-footer border-0 pt-0">
        <button type="button" class="btn btn-danger rounded-pill px-4 w-100" data-bs-dismiss="modal">Got it!</button>
      </div>
    </div>
  </div>
</div>

<script src="/js/map.js"></script>
