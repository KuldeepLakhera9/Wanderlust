<% layout("/layouts/boilerplate") %>

<div id="filters-container" class="mt-2">
  <div id="filters">
    <a href="/listings" class="filter <%= !selectedCategory ? 'active' : '' %>">
      <div><i class="fa-solid fa-border-all"></i></div>
      <p>All</p>
    </a>
    <a href="/listings?category=Trending" class="filter <%= selectedCategory === 'Trending' ? 'active' : '' %>">
      <div><i class="fa-solid fa-fire"></i></div>
      <p>Trending</p>
    </a>
    <a href="/listings?category=Rooms" class="filter <%= selectedCategory === 'Rooms' ? 'active' : '' %>">
      <div><i class="fa-solid fa-bed"></i></div>
      <p>Rooms</p>
    </a>
    <a href="/listings?category=Iconic Cities" class="filter <%= selectedCategory === 'Iconic Cities' ? 'active' : '' %>">
      <div><i class="fa-solid fa-mountain-city"></i></div>
      <p>Iconic Cities</p>
    </a>
    <a href="/listings?category=Mountains" class="filter <%= selectedCategory === 'Mountains' ? 'active' : '' %>">
      <div><i class="fa-solid fa-mountain"></i></div>
      <p>Mountains</p>
    </a>
    <a href="/listings?category=Castles" class="filter <%= selectedCategory === 'Castles' ? 'active' : '' %>">
      <div><i class="fa-solid fa-chess-rook"></i></div>
      <p>Castles</p>
    </a>
    <a href="/listings?category=Camping" class="filter <%= selectedCategory === 'Camping' ? 'active' : '' %>">
      <div><i class="fa-solid fa-campground"></i></div>
      <p>Camping</p>
    </a>
    <a href="/listings?category=Farms" class="filter <%= selectedCategory === 'Farms' ? 'active' : '' %>">
      <div><i class="fa-solid fa-building-wheat"></i></div>
      <p>Farms</p>
    </a>
    <a href="/listings?category=Arctic" class="filter <%= selectedCategory === 'Arctic' ? 'active' : '' %>">
      <div><i class="fa-regular fa-snowflake"></i></div>
      <p>Arctic</p>
    </a>
    <a href="/listings?category=Domes" class="filter <%= selectedCategory === 'Domes' ? 'active' : '' %>">
      <div><i class="fa-solid fa-landmark-dome"></i></div>
      <p>Domes</p>
    </a>
    <a href="/listings?category=Boats" class="filter <%= selectedCategory === 'Boats' ? 'active' : '' %>">
      <div><i class="fa-solid fa-sailboat"></i></div>
      <p>Boats</p>
    </a>
    <a href="/listings?category=Pools" class="filter <%= selectedCategory === 'Pools' ? 'active' : '' %>">
      <div><i class="fa-solid fa-person-swimming"></i></div>
      <p>Pools</p>
    </a>
  </div>

  <div class="d-flex align-items-center gap-3">
    <% if (selectedCategory || searchQuery) { %>
      <a href="/listings" class="btn btn-sm btn-outline-secondary rounded-pill px-3 fw-semibold">
        <i class="fa-solid fa-xmark me-1"></i>Clear Filters
      </a>
    <% } %>

    <div class="tax-toggle">
      <div class="form-check form-switch m-0">
        <input class="form-check-input" type="checkbox" role="switch" id="switchCheckDefault">
        <label class="form-check-label ms-2" for="switchCheckDefault">Display total after taxes</label>
      </div>
    </div>
  </div>
</div>

<% if (searchQuery) { %>
  <div class="my-3 text-muted">
    Showing results for: <span class="fw-bold text-dark">"<%= searchQuery %>"</span>
  </div>
<% } %>

<% if (allListings.length === 0) { %>
  <div class="text-center py-5 my-5">
    <div class="display-1 text-muted mb-3"><i class="fa-solid fa-compass-drafting"></i></div>
    <h3 class="fw-bold">No places found</h3>
    <p class="text-muted">Try adjusting your search terms or clearing selected category filters.</p>
    <a href="/listings" class="btn btn-danger rounded-pill px-4 mt-2">Explore All Listings</a>
  </div>
<% } else { %>
  <!-- Grid View -->
  <div id="listings-grid-view" class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 g-4 mt-1 mb-5">
    <% for(let listing of allListings) { %>
      <div class="col">
        <a href="/listings/<%= listing._id %>" class="listing-link">
          <div class="card listing-card h-100">
            <div class="card-img-wrapper">
              <span class="category-badge"><%= listing.category || 'Trending' %></span>
              <button class="wishlist-btn" data-id="<%= listing._id %>" title="Save to wishlist">
                <i class="fa-regular fa-heart"></i>
              </button>
              <img src="<%= listing.image ? listing.image.url : 'https://images.unsplash.com/photo-1507525428034-b723cf961d3e' %>" class="card-img-top" alt="<%= listing.title %>">
            </div>

            <div class="card-body">
              <h5 class="card-title-text"><%= listing.title %></h5>
              <div class="card-location-text">
                <i class="fa-solid fa-location-dot me-1 text-danger"></i><%= listing.location %>, <%= listing.country %>
              </div>
              <div class="card-price-text base-price" data-raw-price="<%= listing.price %>">
                &#8377;<%= listing.price ? listing.price.toLocaleString("en-IN") : 'N/A' %> <span class="text-muted fs-7">/ night</span>
              </div>
              <div class="tax-info">
                +18% GST &bull; Total &#8377;<%= listing.price ? Math.round(listing.price * 1.18).toLocaleString("en-IN") : 'N/A' %>
              </div>
            </div>
          </div>
        </a>
      </div>
    <% } %>
  </div>

  <!-- Map View Container (Hidden initially) -->
  <div id="listings-map-view" class="d-none mt-3 mb-5">
    <div id="allMap" style="height: 600px;" class="rounded-4 shadow"></div>
  </div>

  <!-- Floating Map Toggle Button -->
  <div class="floating-map-toggle">
    <button id="toggleViewBtn" class="btn btn-dark rounded-pill px-4 py-2 shadow-lg fw-bold d-flex align-items-center gap-2">
      <i class="fa-solid fa-map" id="toggleIcon"></i>
      <span id="toggleText">Show map</span>
    </button>
  </div>
<% } %>

<!-- Embedded Listing Data for Leaflet Map -->
<script>
  window.allListingsData = <%- JSON.stringify(allListings) %>;
</script>
<script src="/js/map.js"></script>